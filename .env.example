# .env.example
# LS 하이브리드 터틀 자동매매 — 환경변수 설정 템플릿
#
# 사용 방법:
#   이 파일을 복사해서 ".env" 라는 이름으로 저장한 뒤,
#   각 항목의 값을 실제 값으로 채운다.
#   .env 파일은 절대 git에 올리지 않는다.

# ─────────────────────────────────────
# LS증권 API 설정
# ─────────────────────────────────────

# LS증권 앱 키 (LS 개발자 포털에서 발급)
LS_APP_KEY=여기에_앱키_입력

# LS증권 앱 시크릿 키
LS_APP_SECRET_KEY=여기에_시크릿키_입력

# 모의투자 여부: True = 모의투자(가상), False = 실계좌(실제 돈)
# 처음에는 반드시 True 로 테스트한다
LS_PAPER_TRADING=True

# 계좌번호 (로그·알림에서 마스킹 처리용 — 뒤 4자리만 써도 됨)
LS_ACCOUNT_NO=여기에_계좌번호_입력

# ─────────────────────────────────────
# 텔레그램 알림 설정
# ─────────────────────────────────────

# 텔레그램 봇 토큰 (BotFather 에서 발급)
TELEGRAM_BOT_TOKEN=여기에_봇토큰_입력

# 텔레그램 채팅 ID (본인 채팅방 또는 그룹 ID)
TELEGRAM_CHAT_ID=여기에_채팅ID_입력

# ─────────────────────────────────────
# Google Sheets 연동 설정 (체결 원장 저장)
# ─────────────────────────────────────

# Google 서비스 계정 JSON 파일 경로 (service_account.json 위치)
# 없으면 Google Sheets 저장이 비활성화되고 로컬 JSON에만 저장됨
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Google Sheets 스프레드시트 제목
GOOGLE_SPREADSHEET_TITLE=하이브리드터틀_체결원장

# (선택) 스프레드시트를 저장할 Google Drive 폴더 ID
# 비워 두면 내 드라이브 루트에 생성됨
GOOGLE_DRIVE_FOLDER_ID=

# ─────────────────────────────────────
# 전략 설정
# ─────────────────────────────────────

# 예외 진입 허용 여부 (1주 가격이 총자본 2~5% 이내일 때 1주 매수)
# True = 허용(기본), False = 스킵
LS_ALLOW_EXCEPTION_ENTRY=True
