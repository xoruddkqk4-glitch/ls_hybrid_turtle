# .env.example
# LS 하이브리드 터틀 자동매매 환경변수 설정 템플릿
#
# 사용법:
#   1. 이 파일을 복사해서 이름을 ".env"로 바꾼다
#   2. 아래 항목에 실제 값을 입력한다
#   3. .env 파일은 절대 외부에 공유하거나 git에 올리지 않는다 (API 키 노출 위험)
#
# ──────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# [필수] LS증권 API 키
# LS OPEN API 개발자 포털(https://openapi.ls-sec.co.kr)에서 앱을 등록하면 발급된다.
# ─────────────────────────────────────────

LS_APP_KEY=여기에_앱키_입력
LS_APP_SECRET_KEY=여기에_시크릿키_입력

# ─────────────────────────────────────────
# [필수] 모의투자 / 실계좌 선택
#
# True  = 모의투자 (주문이 실제로 체결되지 않아 안전 — 개발·테스트 시 사용)
# False = 실계좌  (주문이 실제로 체결됨 — 실전 매매 시 사용, 주의!)
# ─────────────────────────────────────────

LS_PAPER_TRADING=True

# ─────────────────────────────────────────
# [선택] 계좌번호 (마스킹 보관용)
# 체결 원장 기록 시 account_id 필드로 저장된다.
# 전체 계좌번호를 입력하지 말고, 식별용 별칭이나 앞 4자리만 입력한다.
# ─────────────────────────────────────────

LS_ACCOUNT_NO=계좌별칭_또는_앞4자리

# ─────────────────────────────────────────
# [선택] 텔레그램 알림
# 진입·청산·오류 발생 시 스마트폰으로 알림을 받으려면 입력한다.
# 없어도 프로그램은 정상 동작 (알림 대신 화면 출력으로 대체됨).
#
# 발급 방법:
#   1. 텔레그램에서 @BotFather 에게 /newbot 명령으로 봇 생성
#   2. 발급된 토큰을 TELEGRAM_BOT_TOKEN에 입력
#   3. @userinfobot 에게 아무 메시지 보내면 chat_id 확인 가능
# ─────────────────────────────────────────

TELEGRAM_BOT_TOKEN=봇토큰_여기에_입력
TELEGRAM_CHAT_ID=채팅ID_여기에_입력

# ─────────────────────────────────────────
# [선택] Google Sheets 연동
# 체결 내역을 Google 스프레드시트에 자동 기록하려면 입력한다.
# 없어도 프로그램은 정상 동작 (trade_ledger.json 파일에만 저장됨).
#
# 설정 방법:
#   1. Google Cloud Console에서 서비스 계정 생성 및 JSON 키 파일 다운로드
#   2. JSON 파일을 프로젝트 폴더에 저장하고 파일 경로를 아래에 입력
#   3. 시트 제목(GOOGLE_SPREADSHEET_TITLE)은 원하는 이름으로 설정
# ─────────────────────────────────────────

GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
GOOGLE_SPREADSHEET_TITLE=LS Stock Trade History
GOOGLE_DRIVE_FOLDER_ID=

# ─────────────────────────────────────────
# [선택] 예외 진입 허용 여부
# 1주 가격이 총자본의 2%~5% 사이일 때 1주만 매수할지 여부.
# True  = 허용 (기본값) — 비싼 종목도 1주씩 매수
# False = 금지 — 1주 가격이 총자본 2% 초과면 무조건 스킵
# ─────────────────────────────────────────

LS_ALLOW_EXCEPTION_ENTRY=True
